---
import { Code as AstroCode } from "astro:components";

interface Props {
  format?: string;
  lang?: string;
  value: string;
  class?: string;
}

const { format, lang = "plaintext", value, class: className = "" } = Astro.props;

const codeLang = lang as any;
---

<div class={`code-wrapper ${className}`.trim()} data-has-themes="true">
  <div class="code-block theme-code">
    <AstroCode 
      code={value} 
      lang={codeLang} 
      themes={{ light: "github-light" ,dark: "github-dark-default"}}
      defaultColor="light"
    />
  </div>
</div>

<style>
  .code-wrapper {
    margin: 1.5rem 0;
    position: relative;
  }

  .code-block {
    border-radius: 0.375rem;
    overflow-x: auto;
  }

  .code-block :global(pre) {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .code-block :global(code) {
    font-family:var(--font-monospace);
  }
</style>
