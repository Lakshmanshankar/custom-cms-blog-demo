
---
interface Props {
  src: string;
  darkModeSrc?: string;
  altText?: string;
  caption?: string;
  width?: number | string;
  height?: number | string;
  maxWidth?: number | string;
  alignment?: "left" | "center" | "right";
  class?: string;
}

const {
  src,
  darkModeSrc,
  altText = "",
  caption = "",
  width,
  height,
  maxWidth = 1024,
  alignment = "center",
  class: className = "",
} = Astro.props;

const alignmentClass =
  alignment === "left" ? "justify-start" : alignment === "right" ? "justify-end" : "justify-center";

const imageStyle: Record<string, string> = {};
if (maxWidth) imageStyle.maxWidth = typeof maxWidth === "number" ? `${maxWidth}px` : maxWidth;
if (width) imageStyle.width = typeof width === "number" ? `${width}px` : width;
if (height) imageStyle.height = typeof height === "number" ? `${height}px` : height;
---

<div class={`image-wrapper flex ${alignmentClass} ${className}`.trim()} data-has-dark-mode={darkModeSrc ? "true" : "false"}>
  <figure class="image-figure">
    <div class="image-container">
      <img
        src={src}
        alt={altText}
        data-theme="light"
        class="theme-image"
        style={imageStyle}
        width={typeof width === "number" ? width : undefined}
        height={typeof height === "number" ? height : undefined}
      />
      {darkModeSrc && (
        <img
          src={darkModeSrc}
          alt={altText}
          data-theme="dark"
          class="theme-image"
          style={imageStyle}
          width={typeof width === "number" ? width : undefined}
          height={typeof height === "number" ? height : undefined}
        />
      )}
    </div>
    {caption && (
      <figcaption class="image-caption">{caption}</figcaption>
    )}
  </figure>
</div>

<style>
  .image-wrapper {
    margin: 1.5rem 0;
  }

  .image-figure {
    margin: 0;
    display: inline-block;
    max-width: 100%;
  }

  .image-container {
    position: relative;
    display: inline-block;
    max-width: 100%;
  }

  .theme-image {
    display: block;
    height: auto;
    border-radius: 0.25rem;
    border: 1px solid var(--border-color);
  }

  /* Show light image by default, hide dark image */
  .theme-image[data-theme="dark"] {
    display: none;
  }

  /* In dark mode, hide light image and show dark image */
  :global(.dark) .theme-image[data-theme="light"] {
    display: none;
  }

  :global(.dark) .theme-image[data-theme="dark"] {
    display: block;
  }

  .image-caption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    text-align: center;
    color: var(--main-text);
    opacity: 0.7;
  }

  /* If darkModeSrc is not present, always show light image even in dark mode */
  [data-has-dark-mode="false"] .theme-image[data-theme="light"] {
    display: block !important;
  }
</style>
