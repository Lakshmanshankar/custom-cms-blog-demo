---
import Layout from "@/layouts/Layout.astro";
import { getCollection, getEntry, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const workPosts = await getCollection("work");
    return workPosts.map((post: { id: any }) => ({
        params: { slug: post.id },
        props: { post },
    }));
}
interface Props {
    post: CollectionEntry<"work">;
}
const { post } = Astro.props;
const entry = await getEntry("work", post.id);

if (!entry) {
    return new Response("Not Found", {
        status: 404,
        statusText: "Not Found",
    });
}
const { Content } = await render(entry);
const title = entry.data.company || entry.data.title || entry.id;
const role = entry.data.role;
const description = entry.data.description;
const dateLabel = [entry.data.dateStart, entry.data.dateEnd].filter(Boolean).join(" - ");
const techList = entry.data.tech
    ?.split(",")
    .map((tech) => tech.trim())
    .filter(Boolean);
---

<Layout title={title} description={description}>
    <div class="flex flex-col md:flex-row justify-between md:items-center py-4">
        <div>
            <h2 class="mt-0 md:mt-2">{title}</h2>
            {role && <h3 class="mt-0 md:mt-2">{role}</h3>}
        </div>

        {
            dateLabel && (
                <div class="flex tex-sm md:flex-row h-fit gap-2">
                    <h4 class="m-0 h-fit text-sm text-muted-background">{dateLabel}</h4>
                </div>
            )
        }
    </div>
    <p class="mt-2">{description}</p>
    {
        techList && techList.length > 0 && (
            <>
                <span>
                    Tech Stack:
                    <div class="flex flex-wrap">
                        {techList.map((tech) => <span class="tag-btn muted-background">{tech}</span>)}
                    </div>
                </span>
                <br />
            </>
        )
    }
    <Content />
</Layout>
